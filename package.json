{
  "name": "proofos",
  "displayName": "ProofOS — AI Proofreader for Google Docs",
  "description": "LLM-powered proofreading workbench for Google Docs. Default: local Ollama with deepseek-r1:8b. Optional: any OpenAI-compatible API.",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "docker compose up -d languagetool && vite",
    "lt:up": "docker compose up -d languagetool",
    "lt:down": "docker compose down",
    "lt:logs": "docker compose logs -f languagetool",
    "build": "tsc && vite build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,html,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,html,yml}\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "TEST_WATCH_MODE=true vitest --config vitest.e2e.config.ts",
    "typecheck": "tsc",
    "prepare": "husky"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@types/chrome": "^0.1.29",
    "@types/node": "^24.9.2",
    "@types/nspell": "2.1.6",
    "crx3": "^2.0.0",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "pino": "^10.1.1",
    "prettier": "^3.6.2",
    "puppeteer-core": "^24.27.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "user-agent-data-types": "^0.4.2",
    "vite": "^7.0.5",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.0.6"
  },
  "dependencies": {
    "dictionary-en": "4.0.0",
    "nspell": "2.1.5"
  }
}
